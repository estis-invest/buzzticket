# Copy this file to .env and fill in the appropriate values.
DB_USERNAME=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=buzzticket
# --- JPA / Hibernate ---
# Enable SQL logging locally if needed
JPA_SHOW_SQL=false
# Enable SQL logging locally if needed
HIBERNATE_SQL_LOG_LEVEL=DEBUG
HIBERNATE_BIND_LOG_LEVEL=TRACE
HIBERNATE_EXTRACT_LEVEL=TRACE
# --- Flyway ---
# Enable baseline-on-migrate ONLY for one-time adoption of existing schemas
FLYWAY_BASELINE_ON_MIGRATE=false
# BUZZTICKET SECRET PATH TO PEM FILE
BUZZTICKET_PRIVATE_KEY_PATH=file:../keys/jwt-private.pem
BUZZTICKET_PUBLIC_KEY_PATH=file:../keys/jwt-public.pem
# JWT auth configuration
BUZZTICKET_JWT_ISSUER=buzzticket-prod
BUZZTICKET_JWT_AUDIENCE=buzzticket-api
BUZZTICKET_JWT_KEY_ID=buzzticket-jwt-v1
BUZZTICKET_JWT_TTL_SECONDS=900
